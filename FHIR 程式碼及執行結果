# ─────────────────────────────────────────────
# 模擬異常偵測邏輯
# ─────────────────────────────────────────────
def check_vital_signs(spo2, hr, temp):
    alerts = []
    if spo2 < 95:
        alerts.append(f"⚠️  血氧飽和度異常：{spo2}%（正常 ≥95%）")
    if hr > 100 or hr < 60:
        alerts.append(f"⚠️  心率異常：{hr} bpm（正常 60-100 bpm）")
    if temp > 37.2:
        alerts.append(f"⚠️  體溫異常：{temp}°C（正常 36.1-37.2°C）")
    return alerts

